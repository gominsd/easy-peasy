# 네이버 검색 API (https://developers.naver.com/apps 에서 발급)
# 애플리케이션 등록 후 "검색" API 사용 설정 필요
NAVER_CLIENT_ID=여기에_네이버_클라이언트_ID
NAVER_CLIENT_SECRET=여기에_네이버_클라이언트_시크릿

# Google Gemini API 키 (https://aistudio.google.com/apikey 에서 발급)
GEMINI_API_KEY=여기에_GEMINI_API_키

# (선택) 사용할 Gemini 모델. 쉼표로 여러 개 적으면 앞에서부터 시도하고
# 하루 무료 한도(429) 초과 시 다음 모델로 자동 폴백합니다.
GEMINI_MODEL=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash

# (선택) 서버 포트
PORT=3000
